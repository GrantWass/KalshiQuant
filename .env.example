# KalshiQuant environment configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── Kalshi API credentials (required) ─────────────────────────────────────────
# Generate at: Kalshi → Profile → API Keys → Create Key
# Save the private key PEM file and set the path below (relative to repo root).
KALSHI_API_KEY_ID=your-key-id-here
KALSHI_PRIVATE_KEY_PATH=kalshi_private.pem

# ── Database ──────────────────────────────────────────────────────────────────
# Docker: use the service name "postgres" as the host
DATABASE_URL=postgresql://kalshi:kalshi@postgres:5432/kalshiquant
# Local (outside Docker): use localhost
# DATABASE_URL=postgresql://kalshi:kalshi@localhost:5432/kalshiquant

POSTGRES_PASSWORD=kalshi   # used by docker-compose to set the postgres container password

# ── Risk parameters (override defaults from config/settings.py) ────────────────
# Uncomment and adjust to tune the system

# Minimum probability edge to consider trading (default: 0.04 = 4 cents)
# PROBABILITY_SHIFT_MIN=0.04

# Minimum model confidence to place an order (default: 0.60)
# CONFIDENCE_MIN=0.60

# Maximum contracts per market (default: 50)
# MAX_POSITION_PER_MARKET=50

# Maximum total portfolio exposure in USD (default: 500.0)
# MAX_TOTAL_EXPOSURE_USD=500.0

# ── Safety switches ────────────────────────────────────────────────────────────
# Set DRY_RUN=true to run the full pipeline WITHOUT placing real orders.
# Highly recommended for initial testing.
DRY_RUN=true

# ── FAISS index paths (relative to repo root) ──────────────────────────────────
FAISS_INDEX_PATH=faiss_data/market_index.bin
FAISS_METADATA_PATH=faiss_data/market_meta.json

# ── Data retention ────────────────────────────────────────────────────────────
# How many days of history to keep. Older rows are deleted nightly at 3am UTC.
# 90 days = ~1-4GB of DB data at typical trading volume. Reduce to 30 for minimal disk use.
RETENTION_DAYS=90

# ── Latency alert threshold (milliseconds) ────────────────────────────────────
# Dashboard shows a red banner if P95 latency exceeds this value.
LATENCY_TARGET_MS=5000
